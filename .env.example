# GROQ_API_KEY: Required for Groq AI API calls (free tier).
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase (免費方案，用於豐富藥品資料 + 全文搜尋)
# 在 https://supabase.com 建立專案後取得以下兩個值（Settings → API）
# VITE_ 前綴讓 Vite 在前端可讀取，anon key 設計為可公開
VITE_SUPABASE_URL="https://xxxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."

# 僅供 scripts/import-excel.mjs 使用（後端 service_role key，勿提交）
# SUPABASE_URL="https://xxxx.supabase.co"
# SERVICE_ROLE_KEY="eyJ..."
